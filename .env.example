GENAI_DATABASE_BACKEND=postgres
GENAI_POSTGRES_DSN=postgresql://genai_user:genai_password@localhost:5432/genai_service

POSTGRES_DB=genai_service
POSTGRES_USER=genai_user
POSTGRES_PASSWORD=genai_password
POSTGRES_PORT=5432

GENAI_APP_HOST=127.0.0.1
GENAI_APP_PORT=8000
GENAI_WORKER_POLL_INTERVAL=5

# Optional: enable browser/API Basic Auth when both values are set.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
